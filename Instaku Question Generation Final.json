        "jsCode": "const jobId = $('Webhook Trigger').first().json.body.jobId;\nconst totalQuestions = $('Webhook Trigger').first().json.body.inputs.totalQuestions;\nconst serviceKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlkd21jdGhkanZobWlld3ducGZvIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1MzYyMDM2MiwiZXhwIjoyMDY5MTk2MzYyfQ.CmRE4CItRDUged-TKgkNvyCGW4cP7rKzNjigJYJEYZ4';\n\nconst res = await fetch(\n  `https://ydwmcthdjvhmiewwnpfo.supabase.co/rest/v1/generation_job_events?job_id=eq.${jobId}&event_type=eq.passed&select=id`,\n  {\n    headers: {\n      'apikey': serviceKey,\n      'Authorization': `Bearer ${serviceKey}`\n    }\n  }\n);\nconst data = await res.json();\nconst passedCount = Array.isArray(data) ? data.length : 0;\nconst discardedCount = Math.max(0, totalQuestions - passedCount);\n\nreturn [{ json: { jobId, passedCount, discardedCount } }];"
