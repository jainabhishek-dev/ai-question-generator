    {
      "parameters": {
        "jsCode": "const item = $('Webhook Trigger').first();\nconst { jobId, userId, inputs, mode } = item.json.body;\n\nconst questionSlots = [];\n\nconst types = [\n  { type: 'multiple-choice', count: inputs.numMCQ || 0 },\n  { type: 'true-false', count: inputs.numTrueFalse || 0 },\n  { type: 'fill-in-the-blank', count: inputs.numFillBlank || 0 },\n  { type: 'short-answer', count: inputs.numShortAnswer || 0 },\n  { type: 'long-answer', count: inputs.numLongAnswer || 0 }\n];\n\nlet questionIndex = 0;\nfor (const { type, count } of types) {\n  for (let i = 0; i < count; i++) {\n    questionSlots.push({\n      jobId,\n      userId,\n      inputs,\n      mode,\n      questionType: type,\n      questionIndex: questionIndex++\n    });\n  }\n}\n\nreturn questionSlots;"
      },
